# VIPAR portal configuration — copy to .env.local and change for production.

# Neon Postgres connection string (Neon console → Connect → .env snippet).
# With this set: users, dataset versions (rollback), devices, IP allowlist and
# the access log all live in the database. Run `npx tsx scripts/migrate.ts` once.
DATABASE_URL=

# Login credentials. With a database these are only used as SEEDS by the
# migration script; without a database they are the live fallback credentials.
# Roles: client (dashboard only), uploader (dashboard + upload), admin (everything).
VIPAR_USER=vipar
VIPAR_PASS=vipar
VIPAR_UPLOADER_USER=upload
VIPAR_UPLOADER_PASS=upload
VIPAR_ADMIN_USER=admin
VIPAR_ADMIN_PASS=123456

# Secret used to sign session cookies. Set a long random string in production.
AUTH_SECRET=change-me-to-a-long-random-string

# Maximum number of devices that can register via trust-on-first-use.
# Reset registered devices by deleting data/devices.json.
MAX_DEVICES=3

# Session lifetime in hours.
SESSION_HOURS=168

# Optional network allowlist for /dashboard and /admin.
# Comma separated. Exact IPs, or prefixes ending with a dot.
# Leave empty to disable. Localhost is always allowed.
# ALLOWED_IPS=103.120.45.10,196.223.11.
ALLOWED_IPS=
